@addTagHelper *, Nop.Web.Framework
@model Nop.Plugin.Misc.AbandonedCartReminder.Models.ConfigurationModel

@{
    Layout = "_ConfigurePlugin";
}

<form asp-controller="AbandonedCartReminder" asp-action="Configure" method="post">

@Html.AntiForgeryToken()
    <div class="cards-group">
        <div class="card card-default">
            <div class="card-header">
                Abandoned Cart Reminder Settings
            </div>
            <div class="card-body">
                <div class="form-group row">
                    <div class="col-md-3">
                        <label class="control-label">Send After Hours</label>
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="SendAfterHours" />
                        <span asp-validation-for="SendAfterHours"></span>
                    </div>
                </div>

                <div class="form-group row">
                    <div class="col-md-3">
                        <label class="control-label">Enabled</label>
                    </div>
                    <div class="col-md-9">
                        <nop-editor asp-for="Enabled" />
                        <span asp-validation-for="Enabled"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card card-default">
            <div class="card-body">
                <button type="submit" class="btn btn-primary">
                    Save
                </button>
            </div>
        </div>
    </div>
</form>