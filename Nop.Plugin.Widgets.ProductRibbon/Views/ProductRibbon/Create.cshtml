@model Nop.Plugin.Widgets.ProductRibbon.Models.ProductRibbonModel

@{
    Layout = "_AdminLayout";
    ViewBag.PageTitle = "Create Ribbon";
    NopHtml.SetActiveMenuItemSystemName("ProductRibbon.List");
}

<form asp-controller="ProductRibbon" asp-action="Create" method="post">
    <div class="content-header clearfix">
        <h1 class="float-left">
            Create Ribbon
        </h1>
        <div class="float-right">
            <button type="submit" name="save" class="btn btn-primary">
                <i class="far fa-save"></i>
                Save
            </button>
            <a asp-controller="ProductRibbon" asp-action="List" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i>
                Back to list
            </a>
        </div>
    </div>

    <section class="content">
        <div class="container-fluid">
            <div asp-validation-summary="All"></div>

            <nop-cards id="productribbon-create-cards">
                <nop-card asp-name="productribbon-create-info"
                          asp-icon="fas fa-info"
                          asp-title="Ribbon Info"
                          asp-hide-block-attribute-name="ProductRibbonCreate.Info"
                          asp-hide="false"
                          asp-advanced="false">

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="Name" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="Name" />
                            <span asp-validation-for="Name"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="BackgroundColor" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="BackgroundColor" />
                            <span asp-validation-for="BackgroundColor"></span>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="TextColor" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="TextColor" />
                            <span asp-validation-for="TextColor"></span>
                        </div>
                    </div>

                   <div class="form-group row">
    <div class="col-md-3">
        <nop-label asp-for="IsActive" />
    </div>
    <div class="col-md-9">
       <div class="form-check">
    <input class="form-check-input"
           type="checkbox"
           id="IsActive"
           name="IsActive"
           value="true" />
    <input type="hidden" name="IsActive" value="false" />
</div>
        <span asp-validation-for="IsActive"></span>
    </div>
</div>

                </nop-card>
            </nop-cards>
        </div>
    </section>
</form>